{
  "manifest_version": 2,
  "name": "PageZipper",
  "version": "1.5.1",
  "description": "Painlessly merge a series of web pages into one.",
  "homepage_url": "https://o9ll.com/pagezipper",
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "icons/16.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  },

  "applications": {
    "gecko": {
      "id": "pagezipper@o9ll.com",
      "strict_min_version": "48.0",
      "strict_max_version": "*"
    }
  },

  "background": {
    "scripts": [
      "options/common.js",
      "background.js",
      "common/background-common.js"
    ]
  },

  "browser_action": {
    "default_icon": "icons/32.png",
    "default_title": "PageZipper"
  },

  "web_accessible_resources": ["*"],

  "permissions": [
    "tabs",
    "https://*/*",
    "https://*/*",
    "activeTab",
    "storage",
    "webNavigation"
  ]
}
